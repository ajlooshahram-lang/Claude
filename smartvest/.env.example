# SmartVest Environment Variables
# For LOCAL development: copy to backend/.env
# For PRODUCTION: set in your hosting dashboard (Railway, Render, etc.)

# OpenAI API key (OPTIONAL — app works without it)
# Get free at: https://platform.openai.com/api-keys
# Cost: ~$0.01-0.05 per AI chat conversation
OPENAI_API_KEY=

# Saxo Bank Broker Connection (OPTIONAL — enables real portfolio sync)
# Get free at: https://www.developer.saxo (create account, register an app)
# Use SIM environment first (no real money needed)
SAXO_CLIENT_ID=
SAXO_CLIENT_SECRET=
SAXO_REDIRECT_URI=http://localhost:3000/broker-callback
SAXO_ENV=SIM

# Server settings (defaults work fine for local)
HOST=0.0.0.0
PORT=8000
