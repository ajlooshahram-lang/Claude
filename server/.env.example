# ---------------------------------------------------------------------------
# QI Platform backend — example environment. Copy to .env and fill real values.
# NEVER commit a real .env. Secrets belong in your host's secret manager.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=8080
# Comma-separated list of allowed browser origins (the web UI). No wildcard in prod.
CORS_ORIGINS=http://localhost:5173

# PostgreSQL connection (EU-resident instance for GDPR). Use TLS in production.
DATABASE_URL=postgresql://qi:qi@localhost:5432/qi_platform?schema=public&sslmode=prefer

# Session signing secret — generate a long random value: `openssl rand -hex 32`
SESSION_SECRET=change-me-to-a-32-byte-random-hex-string

# How often the maintenance job runs, in minutes (min 1). The job hard-deletes
# expired session rows and (optionally) rotates audit logs. Defaults to hourly.
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Audit-log retention window in days. 0 = keep audit logs forever (the default).
# Audit logs are a compliance record, so they are NEVER deleted unless you
# explicitly opt in by setting this above 0 (then rows older than N days are
# purged by the maintenance job).
AUDIT_LOG_RETENTION_DAYS=0

# Application-level encryption key for secrets at rest (e.g. tenant AI keys).
# 32-byte base64 value: `openssl rand -base64 32`
DATA_ENCRYPTION_KEY=change-me-base64-32-bytes

# Data residency region tag, surfaced in health/readiness for auditability.
DATA_REGION=eu-west
