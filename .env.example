# QI Platform - Required Environment Variables
# Copy this file to .env and fill in your values before running docker-compose up.

# PostgreSQL credentials
POSTGRES_USER=qi
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=qi_platform

# Session signing secret (minimum 16 characters)
SESSION_SECRET=change-me-minimum-16-chars

# AES-256-GCM encryption key for MFA secrets at rest.
# Must be exactly 64 hex characters (representing 32 bytes).
# Generate with: openssl rand -hex 32
DATA_ENCRYPTION_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost
