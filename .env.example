# ---------------------------------------------------------------------------
# STP Platform — Docker Compose environment variables
# Copy this file to .env and replace all placeholder values with real secrets.
# NEVER commit the real .env file.
# ---------------------------------------------------------------------------
#
# TLS REQUIREMENT:
# Session cookies use the Secure flag in production (NODE_ENV=production),
# which requires HTTPS. You MUST place a TLS-terminating reverse proxy
# (e.g., Cloudflare Tunnel, Caddy, Traefik, or cloud load balancer) in front
# of nginx before deploying to production. For local development/testing
# without TLS, set NODE_ENV=development.
# ---------------------------------------------------------------------------

# PostgreSQL
POSTGRES_USER=stp
POSTGRES_PASSWORD=changeme-use-openssl-rand-hex-16
POSTGRES_DB=stp_platform

# Backend
SESSION_SECRET=changeme-use-openssl-rand-hex-32
DATA_ENCRYPTION_KEY=changeme-use-openssl-rand-base64-32
NODE_ENV=production
DATA_REGION=eu-west

# Maintenance job (expired-session cleanup + optional audit-log rotation).
# Interval in minutes (min 1, default 60 = hourly).
SESSION_CLEANUP_INTERVAL_MINUTES=60
# Audit-log retention in days. 0 = keep forever (default). Audit logs are a
# compliance record and are never deleted unless you opt in by setting > 0.
AUDIT_LOG_RETENTION_DAYS=0

# Admin seed (used by prisma/seed.ts)
ADMIN_EMAIL=admin@stp.local
ADMIN_PASSWORD=
# ^ REQUIRED: Set a strong password (12+ characters) before running the seed.

# ---------------------------------------------------------------------------
# Secret generation commands:
#   openssl rand -hex 16    -> POSTGRES_PASSWORD
#   openssl rand -hex 32    -> SESSION_SECRET
#   openssl rand -base64 32 -> DATA_ENCRYPTION_KEY
# ---------------------------------------------------------------------------
